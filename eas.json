{
  "cli": {
    "version": ">= 16.6.2",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "development-simulator": {
        "developmentClient": true,
        "distribution": "internal",
        "ios": {
            "simulator": true
        },
        "env": {
            "APP_VARIANT": "development"
        },
        "channel": "development-simulator"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
